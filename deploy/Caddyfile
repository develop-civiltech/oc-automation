# Mientras no haya dominio propio: sirve HTTP plano en el puerto 80 de la IP del VPS.
:80 {
	reverse_proxy app:3001
}

# ── Cuando llegue el dominio ──────────────────────────────────────────────────
# 1. Apuntar el registro DNS A del dominio a la IP de este VPS.
# 2. Reemplazar el bloque ":80 { ... }" de arriba por el dominio, por ejemplo:
#
#      erp.civiltechic.com {
#          reverse_proxy app:3001
#      }
#
#    Caddy emite y renueva el certificado Let's Encrypt automáticamente — no hace
#    falta configurar nada más aquí.
# 3. Actualizar en el .env del VPS:
#      AUTH_REDIRECT_URI=https://erp.civiltechic.com/auth/callback
# 4. Registrar esa misma URL como Redirect URI en Azure AD (App registration →
#    Autenticación) y reiniciar los servicios (`docker compose up -d`).
