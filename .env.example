# ── Rutas a las bases de datos ────────────────────────────────────────────────
# Ajustar según la ubicación real de los archivos en el servidor

PATH_COMPRAS=./data/compras.csv
PATH_PROVEEDORES=./data/proveedores_depurados_final.csv
PATH_PROYECTOS=./data/tabla_proyectos.csv

# ── Microsoft Graph API (para leer correos de Outlook) ────────────────────────
# Obtener estos valores del portal Azure AD (App Registration)
TENANT_ID=7eecb0b2-8a95-4a99-8a71-86257bf74b06
CLIENT_ID=4af79357-1df7-412b-90c1-eb8ad25507ae
CLIENT_SECRET=da28a385-aea8-4777-98b4-a59c9d3919fd

# ── SharePoint (sitio con las listas: Requerimientos, OrdenesCompra, etc.) ────
SHAREPOINT_HOSTNAME=civiltechic562.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/Gestion-de-Proyectos

# ── Buzón a monitorear ────────────────────────────────────────────────────────
MAILBOX=abastecimiento@civiltechic.com

# ── Identificación del usuario (para auditoría y bootstrap del admin inicial) ─
# El nombre y cargo del firmante ya no salen de acá: el nombre se toma del
# login de Microsoft y el cargo se edita en el panel de usuarios (/usuarios).
USUARIO_EMAIL=correo@civiltechic.com

# ── Carpeta de salida para OCs generadas ─────────────────────────────────────
# Puede ser ruta local, OneDrive o SharePoint
OUTPUT_DIR=./output/ordenes_compra

# ── Intervalo de polling en minutos (si no se usa webhook) ────────────────────
POLLING_INTERVAL_MIN=5

# ── SQLite local (caché de lecturas) ──────────────────────────────────────────
SQLITE_PATH=./data/local.db          # ruta al archivo de base de datos local
SYNC_INTERVAL_MIN=2                   # frecuencia de sync SharePoint → SQLite (minutos)

# ── Autenticación ERP (Microsoft OAuth) ──────────────────────────────────────
# Debe coincidir exactamente con la redirect_uri registrada en Azure AD (plataforma "Web").
# Para acceso local: http://localhost:3001/auth/callback
# Para Cloudflare Tunnel: https://erp.civiltechic.com/auth/callback
AUTH_REDIRECT_URI=http://localhost:3001/auth/callback

# ── IA (extracción de PDFs/cotizaciones y matching semántico) ────────────────
# Obtener en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<api-key>
# Modelo de Gemini (opcional). Por defecto gemini-flash-latest.
# gemini-flash-latest es un alias que Google mantiene apuntando al modelo flash
# GA vigente, así que no hay que rotar el modelo a mano cuando Google retira una
# versión (como pasó con gemini-2.5-flash y gemini-3.5-flash). Si en algún momento
# necesitas comportamiento determinista, fija aquí una versión concreta
# (p. ej. gemini-3.6-flash) — basta con cambiar este valor sin tocar código.
GEMINI_MODEL=gemini-flash-latest

# ── Numeración de OC / OS ──────────────────────────────────────────────────────
OC_PREFIX=OC-
OC_PAD=4
OS_PREFIX=OS-
OS_PAD=4
# Consecutivo inicial si el historial en SQLite/SharePoint está vacío (opcional)
# CONTADOR_OC_INICIAL=1
# CONTADOR_OS_INICIAL=1

# ── Adjuntos de correo (descarga temporal, se puede dejar por defecto) ────────
# DIR_ADJUNTOS=./temp/adjuntos

# ── Zona horaria ────────────────────────────────────────────────────────────
# Debe fijarse explícitamente en Docker/Linux para que el horario laboral del
# procesamiento automático de correos (cron) se evalúe en hora de Colombia.
TZ=America/Bogota
